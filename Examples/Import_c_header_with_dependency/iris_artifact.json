{
    "name": "Import_c_header_with_dependency",
    "version": "0.1.0",
    "type": "library",
    "dependencies": [],
    "sources": [
        {
            "type": "iris",
            "include": [
                "./**/*.iris"
            ]
        },
        {
            "type": "export_c_header",
            "include": [
                "./module_a.iris"
            ]
        },
        {
            "type": "import_c_header",
            "headers": [
                {
                    "name": "my_library.module_b",
                    "header": "module_b.h",
                    "dependencies": [
                        "my_library.module_a"
                    ]
                }
            ],
            "public_prefixes": [
                "my_library_module_b_"
            ],
            "remove_prefixes": [
                "my_library_module_b_"
            ]
        }
    ]
}
