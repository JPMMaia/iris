		"cmake.configureSettings": {
			"CMAKE_TOOLCHAIN_FILE": "${workspaceFolder}/../vcpkg/scripts/buildsystems/vcpkg.cmake"
		},
		"cmake.configureArgs": [
			//"--debug-find"
		],
		"cmake.buildArgs": [
			//"--verbose"
		],
		"cmake.configureOnOpen": false,
		"C_Cpp.formatting": "vcFormat",
		"[json]": {
			"editor.defaultFormatter": "vscode.json-language-features"
		},
		"[jsonc]": {
			"editor.defaultFormatter": "vscode.json-language-features"
		},
		"C_Cpp.vcFormat.newLine.beforeOpenBrace.lambda": "newLine",
		"C_Cpp.vcFormat.indent.lambdaBracesWhenParameter": false,
		"testMate.cpp.test.advancedExecutables": [
			{
				"pattern": "{build,Build,BUILD,out,Out,OUT}/**/Debug/*{test,Test,TEST}*",
				"cwd": "${workspaceFolder}/build",
				"name": "Debug ${filename}"
			},
			{
				"pattern": "{build,Build,BUILD,out,Out,OUT}/**/Release/*{test,Test,TEST}*",
				"cwd": "${workspaceFolder}/build",
				"name": "Release ${filename}"
			}
		],
		"editor.formatOnSave": false,
		"terminal.integrated.profiles.windows": {
			"Powershell + VsDevEnv": {
				"source": "PowerShell",
				"args": [
					"-NoExit",
					"-File",
					"${workspaceFolder}/Scripts/Enter-VsDevEnv.ps1"
				]
			}
		},
		"terminal.integrated.defaultProfile.windows": "Powershell + VsDevEnv",
		"C_Cpp.default.cppStandard": "c++23",
		"C_Cpp.default.cStandard": "c23",
		"C_Cpp.default.compileCommands": [
			"${workspaceFolder}/build/compile_commands.json"
		],
		"cmake.automaticReconfigure": false,
		"cmake.buildBeforeRun": false,
		"cmake.configureOnEdit": false,
		"cmake.enableAutomaticKitScan": false,
		"chat.tools.terminal.autoApprove": {
			"Enter-VsDevEnv": true,
			"cmake": true,
			"./build/Source/Compiler/Debug/Iris_compiler_tests.exe": true
		}
