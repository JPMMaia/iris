{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "iris",
      "camelcase": "Iris",
      "title": "Iris",
      "scope": "source.iris",
      "file-types": [
        "iris"
      ],
      "injection-regex": "^iris$",
      "class-name": "TreeSitterIris"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Iris grammar for tree-sitter",
    "authors": [
      {
        "name": "João Maia",
        "email": "jpmmaia@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/JPMMaia/H"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}