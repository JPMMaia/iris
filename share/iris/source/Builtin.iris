module iris.builtin;

export enum Type_kind
{
    Int,
    Uint,
    Float,
    Decimal,
    Bool,
    Struct,
    Union,
    Enum,
    Pointer,
    Array_slice,
    Constant_array,
    Function_pointer,
    Builtin,
    Custom,
    Null_pointer,
}

export struct Generic_array_slice
{
    data: *Byte = null;
    length: Uint64 = 0u64;
}

export struct String
{
    data: *Byte = null;
    length: Uint64 = 0u64;
}

export struct String_view
{
    data: *Byte = null;
    length: Uint64 = 0u64;
}
