{
  "name": "hlang-language-server",
  "displayName": "Hlang Language Server",
  "description": "Language server for the Hlang programming language",
  "version": "0.0.1",
  "publisher": "JPMMaia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JPMMaia/H"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [],
  "main": "./dist/client.js",
  "activationEvents": [],
  "contributes": {
    "breakpoints": [
      {
        "language": "hlang"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Configuration",
      "properties": {
        "hlang_language_server.hlang_executable": {
          "scope": "resource",
          "type": "string",
          "default": "hlang",
          "description": "Specify the file path to the hlang executable."
        },
        "hlang_language_server.hlang_language_server_executable": {
          "scope": "resource",
          "type": "string",
          "default": "hlang_language_server",
          "description": "Specify the file path to the hlang language server executable."
        },
        "hlang_language_server.repositories": {
          "scope": "resource",
          "type": "array",
          "default": [],
          "description": "Specify repositories that specify additional projects that can be added as dependencies to your project."
        },
        "hlang_language_server.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        }
      }
    },
    "grammars": [
      {
        "language": "hlang",
        "scopeName": "source.hlang",
        "path": "./syntaxes/hlang.tmGrammar.json"
      }
    ],
    "languages": [
      {
        "id": "hlang",
        "extensions": [
          ".hltxt"
        ],
        "configuration": "./language_configuration.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -b",
    "compile:client_test": "tsc -b ./packages/client/src/test && npm run webpack:client",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint ./client/src ./server/src --ext .ts,.tsx",
    "watch": "npm run prebuild && tsc -b -w",
    "watch:client": "webpack --mode development --config ./packages/client/webpack.config.js --watch",
    "watch:client_test": "tsc -b -w ./packages/client/src/test",
    "test:extension": "sh ./scripts/e2e.sh",
    "test:scripts": "mocha",
    "clean": "rimraf out",
    "webpack:development": "npm run compile && npm run webpack:client-dev",
    "webpack:client-dev": "tsc -b && tsc -b ./packages/client/src/test && webpack --mode development --config ./packages/client/webpack.config.js",
    "webpack:production": "npm run compile && npm run webpack:client",
    "webpack:client": "webpack --mode production --config ./packages/client/webpack.config.js --devtool hidden-source-map",
    "vscode:prepublish": "npm run webpack:client",
    "webpack": "npm run compile && npm run webpack:client",
    "package": "vsce package",
    "prebuild": "cpy dist/tree-sitter-hlang.wasm out/packages/core/src/"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.9",
    "@types/node": "^22.13.9",
    "@types/object-hash": "^3.0.6",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.12.2",
    "@typescript-eslint/parser": "^8.12.2",
    "cpy-cli": "^5.0.0",
    "eslint": "^9.14.0",
    "merge-options": "^3.0.4",
    "mocha": "^10.8.2",
    "rimraf": "^6.0.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@vscode/vsce": "^3.6.0",
    "fast-array-diff": "^1.1.0",
    "object-hash": "^3.0.0"
  },
  "private": true,
  "workspaces": [
    "packages/client"
  ]
}
